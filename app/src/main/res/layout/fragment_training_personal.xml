<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- KROK 1: Výber osobnej vety -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/selectWrapper"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/textTitleSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/training_personal_title_select"
            android:textStyle="bold"
            android:textSize="22sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/inputPersonalSentence"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/training_personal_hint_input"
            android:layout_marginTop="24dp"
            android:inputType="text"
            app:layout_constraintTop_toBottomOf="@id/textTitleSelect"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/buttonSetSentence"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/training_personal_button_set"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/inputPersonalSentence"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>



    <!-- KROK 2: Tréning opakovania -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/trainingWrapper"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Nadpis tréningu -->
        <TextView
            android:id="@+id/textTitleTraining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/training_personal_title"
            android:textStyle="bold"
            android:textSize="22sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Veta NA ODPISOVANIE (normal weight) -->
        <TextView
            android:id="@+id/textPersonalSentence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/textTitleTraining"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/editTextRepeat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/training_personal_hint_repeat"
            android:layout_marginTop="24dp"
            android:inputType="text"
            app:layout_constraintTop_toBottomOf="@id/textPersonalSentence"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/textProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/training_progress_prefix"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/editTextRepeat"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


        <!-- 🔥 FrameLayout pre NEXT + ProgressBar -->
        <FrameLayout
            android:id="@+id/trainingButtonContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/textProgress"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonNext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="10dp"
                android:text="@string/training_button_next"
                android:textColor="@android:color/white"
                android:enabled="false"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="12dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:indeterminateTint="@android:color/white"
                android:visibility="gone" />

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
