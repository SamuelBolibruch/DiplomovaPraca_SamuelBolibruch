<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true"
    tools:context=".ui.training.TrainingPersonalFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="48dp"
        android:paddingBottom="34dp">

        <LinearLayout
            android:id="@+id/selectWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/trainingChipSelect"
                style="@style/TextAppearance.DiplomovaPraca.TrainingChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_training_chip"
                android:paddingHorizontal="18dp"
                android:paddingVertical="9dp"
                android:text="@string/training_chip_label" />

            <TextView
                android:id="@+id/textTitleSelect"
                style="@style/TextAppearance.DiplomovaPraca.ScreenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="@string/training_personal_title_select" />

            <TextView
                android:id="@+id/labelPersonalSentence"
                style="@style/TextAppearance.DiplomovaPraca.SectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="34dp"
                android:text="@string/auth_mode_personal_sentence" />

            <EditText
                android:id="@+id/inputPersonalSentence"
                style="@style/Widget.DiplomovaPraca.OutlinedInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="top|start"
                android:hint="@string/training_personal_hint_input"
                android:importantForAutofill="no"
                android:inputType="textMultiLine"
                android:minLines="4" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSetSentence"
                style="@style/Widget.DiplomovaPraca.PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/training_personal_button_set" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/trainingWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/trainingChipRepeat"
                style="@style/TextAppearance.DiplomovaPraca.TrainingChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_training_chip"
                android:paddingHorizontal="18dp"
                android:paddingVertical="9dp"
                android:text="@string/training_chip_label" />

            <TextView
                android:id="@+id/textTitleTraining"
                style="@style/TextAppearance.DiplomovaPraca.ScreenTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="@string/training_personal_title" />

            <TextView
                android:id="@+id/textPersonalSentence"
                style="@style/TextAppearance.DiplomovaPraca.Sentence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_sentence_box"
                android:padding="24dp" />

            <EditText
                android:id="@+id/editTextRepeat"
                style="@style/Widget.DiplomovaPraca.OutlinedInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/training_personal_hint_repeat"
                android:importantForAutofill="no"
                android:inputType="text" />

            <View
                android:id="@+id/progressLine"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_progress_line" />

            <TextView
                android:id="@+id/textProgress"
                style="@style/TextAppearance.DiplomovaPraca.Status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/training_progress_prefix"
                android:textAlignment="viewEnd" />

            <FrameLayout
                android:id="@+id/trainingButtonContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonNext"
                    style="@style/Widget.DiplomovaPraca.PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:text="@string/training_button_next" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="@android:color/white"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
