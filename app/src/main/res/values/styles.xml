<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.DiplomovaPraca.ScreenTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="TextAppearance.DiplomovaPraca.SectionLabel" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TextAppearance.DiplomovaPraca.Link" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="TextAppearance.DiplomovaPraca.TrainingChip" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TextAppearance.DiplomovaPraca.Sentence" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/brand_primary_dark</item>
        <item name="android:textSize">18sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="TextAppearance.DiplomovaPraca.Status" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.DiplomovaPraca.OutlinedInput" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_input_outline</item>
        <item name="android:minHeight">64dp</item>
        <item name="android:paddingHorizontal">22dp</item>
        <item name="android:paddingVertical">18dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:textSize">17sp</item>
    </style>

    <style name="Widget.DiplomovaPraca.PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">64dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="cornerRadius">18dp</item>
        <item name="rippleColor">@color/brand_primary_dark</item>
    </style>

    <style name="Widget.DiplomovaPraca.TopActionButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">44dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeColor">@color/brand_primary</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.DiplomovaPraca.PillToggle" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="android:background">@drawable/bg_toggle_pill</item>
        <item name="android:button">@null</item>
        <item name="android:buttonTint">@color/toggle_indicator</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:textColor">@color/toggle_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.DiplomovaPraca.SelectionCard" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="android:background">@drawable/bg_selection_card</item>
        <item name="android:buttonTint">@color/toggle_indicator</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">58dp</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:textColor">@color/toggle_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>




